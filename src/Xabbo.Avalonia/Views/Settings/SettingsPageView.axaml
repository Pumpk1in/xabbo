<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sys="using:System"
  xmlns:ui="using:FluentAvalonia.UI.Controls"
  xmlns:ic="using:FluentIcons.Avalonia.Fluent"
  xmlns:icm="using:FluentIcons.Avalonia.Fluent.MarkupExtensions"
  xmlns:controls="using:Xabbo.Avalonia.Controls"
  xmlns:v="using:Xabbo.Avalonia.Views"
  xmlns:vm="using:Xabbo.ViewModels"
  xmlns:models="using:Xabbo.Models"
  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
  x:Class="Xabbo.Avalonia.Views.SettingsPageView"
  x:Name="SettingsPageViewRoot"
  x:DataType="vm:SettingsPageViewModel"
>
  <UserControl.Resources>
    <sys:Int32 x:Key="IntervalRounding">10</sys:Int32>
  </UserControl.Resources>
  <ScrollViewer>
    <StackPanel Margin="10" Spacing="10">
      <!-- Chat -->
      <ui:SettingsExpander
        Header="Chat log"
        IconSource="{icm:SymbolIconSource Symbol=Chat}"
      >
        <ui:SettingsExpanderItem>
          <StackPanel>
            <TextBlock Margin="0,0,12,0" VerticalAlignment="Center">Messages</TextBlock>
            <WrapPanel>
              <CheckBox IsChecked="{Binding Config.Chat.Log.Normal}" Content="Users" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.Whispers}" Content="Whispers" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.Wired}" Content="Wired" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.Pets}" Content="Pets" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.Bots}" Content="Bots" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.Trades}" Content="Trades" />
              <CheckBox IsChecked="{Binding Config.Chat.Log.UserEntry}" Content="User enters or leaves" />
            </WrapPanel>
          </StackPanel>
        </ui:SettingsExpanderItem>
        <ui:SettingsExpanderItem>
          <StackPanel Spacing="8">
            <TextBlock
              Text="Normal bubbles"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              FontSize="12"
            />
            <ListBox
              ItemsSource="{x:Static vm:SettingsPageViewModel.NormalBubbles}"
              SelectedItem="{Binding SelectedNormalBubble}"
              SelectionMode="Single"
              Background="Transparent"
              BorderThickness="0"
            >
              <ListBox.Resources>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected">#9b8aff</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver">#9b8aff</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed">#9b8aff</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver">#9b8aff</SolidColorBrush>
              </ListBox.Resources>
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="2" />
                  <Setter Property="Margin" Value="2" />
                  <Setter Property="MinWidth" Value="0" />
                  <Setter Property="MinHeight" Value="0" />
                  <Setter Property="CornerRadius" Value="4" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
                  <Setter Property="IsVisible" Value="false" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="models:ChatBubbleOption">
                  <Image
                    Stretch="None"
                    Source="{Binding ., Converter={StaticResource BubbleImageConverter}}"
                    ToolTip.Tip="{Binding Name}"
                  />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <Separator />
            <TextBlock
              Text="Special bubbles (required ingame permissions)"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              FontSize="12"
            />
            <ListBox
              ItemsSource="{x:Static vm:SettingsPageViewModel.OtherBubbles}"
              SelectedItem="{Binding SelectedOtherBubble}"
              SelectionMode="Single"
              Background="Transparent"
              BorderThickness="0"
            >
              <ListBox.Resources>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected">#5000AA</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver">#5000AA</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed">#5000AA</SolidColorBrush>
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver">#33FFFFFF</SolidColorBrush>
              </ListBox.Resources>
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="2" />
                  <Setter Property="Margin" Value="2" />
                  <Setter Property="MinWidth" Value="0" />
                  <Setter Property="MinHeight" Value="0" />
                  <Setter Property="CornerRadius" Value="4" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
                  <Setter Property="IsVisible" Value="false" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="models:ChatBubbleOption">
                  <Image
                    Stretch="None"
                    Source="{Binding ., Converter={StaticResource BubbleImageConverter}}"
                    ToolTip.Tip="{Binding Name}"
                  />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </ui:SettingsExpanderItem>
        <ui:SettingsExpanderItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock VerticalAlignment="Center">
              <Run Text="History:" />
              <Run Text="{Binding HistoryEntryCount}" />
              <Run Text="entries" />
            </TextBlock>
            <Button Content="Clear History" Command="{Binding ClearHistoryCmd}" />
          </StackPanel>
        </ui:SettingsExpanderItem>
      </ui:SettingsExpander>
      <!-- Timing (modern) -->
      <ui:SettingsExpander
        Classes="modern"
        Header="Timing"
        IconSource="{icm:SymbolIconSource Symbol=Timer}"
        Description="Adjust timing intervals"
      >
        <controls:TimingSlider
          Text="User moderation interval"
          Tip="The time interval between moderating users"
          Value="{Binding Config.Timing.Modern.ModerationInterval}"
        />
        <controls:TimingSlider
          Text="Bounce unban delay"
          Tip="When bouncing a user, the time to wait after banning the user, before unbanning the user again"
          Value="{Binding Config.Timing.Modern.BounceUnbanDelay}"
        />
        <controls:TimingSlider
          Text="Furni placement interval"
          Tip="The time interval between placing furni"
          Value="{Binding Config.Timing.Modern.FurniPlaceInterval}"
        />
        <controls:TimingSlider
          Text="Furni pickup interval"
          Tip="The time interval between picking up or ejecting furni"
          Value="{Binding Config.Timing.Modern.FurniPickupInterval}"
        />
        <controls:TimingSlider
          Text="Furni toggle interval"
          Tip="The time interval between toggling furni"
          Value="{Binding Config.Timing.Modern.FurniToggleInterval}"
        />
        <controls:TimingSlider
          Text="Furni move interval"
          Tip="The time interval between moving or rotating furni"
          Value="{Binding Config.Timing.Modern.FurniMoveInterval}"
        />
      </ui:SettingsExpander>
      <!-- Timing (Origins) -->
      <ui:SettingsExpander
        Classes="origins"
        Header="Timing"
        IconSource="{icm:SymbolIconSource Symbol=Timer}"
        Description="Adjust timing intervals"
      >
        <controls:TimingSlider
          Text="User moderation interval"
          Tip="The time interval between moderating users"
          Value="{Binding Config.Timing.Origins.ModerationInterval}"
        />
        <controls:TimingSlider
          Text="Furni placement interval"
          Tip="The time interval between placing furni"
          Value="{Binding Config.Timing.Origins.FurniPlaceInterval}"
        />
        <controls:TimingSlider
          Text="Furni pickup interval"
          Tip="The time interval between picking up or ejecting furni"
          Value="{Binding Config.Timing.Origins.FurniPickupInterval}"
        />
        <controls:TimingSlider
          Text="Furni toggle interval"
          Tip="The time interval between toggling furni"
          Value="{Binding Config.Timing.Origins.FurniToggleInterval}"
        />
        <controls:TimingSlider
          Text="Furni move interval"
          Tip="The time interval between moving or rotating furni"
          Value="{Binding Config.Timing.Origins.FurniMoveInterval}"
        />
        <controls:TimingSlider
          Text="Trade offer interval"
          Tip="The time interval between offering items in a trade"
          Value="{Binding Config.Timing.Origins.TradeOfferInterval}"
        />
      </ui:SettingsExpander>
      <ui:SettingsExpander
        Header="Room furni view"
        IconSource="{icm:SymbolIconSource Symbol=Couch}"
      >
        <controls:TimingSlider
          Text="Dynamic filter refresh interval"
          Description="The time interval between filter refreshes while a dynamic filter is active. Lower values are more responsive but may cause issues when many furni are updating frequently."
          Value="{Binding Config.View.Furni.RefreshIntervalMs}"
        />
      </ui:SettingsExpander>
      <!-- Profanity Filter -->
      <ui:SettingsExpander
        Header="Profanity filter"
        IconSource="{icm:SymbolIconSource Symbol=TextBulletListSquareWarning}"
        Description="Detect profanity in chat messages"
      >
        <ui:SettingsExpanderItem>
          <StackPanel Spacing="10">
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
              Add custom words/phrases to detect in addition to the default list.
              One word or phrase per line. Changes are applied when you click Apply.
            </TextBlock>
            <TextBox
              AcceptsReturn="True"
              TextWrapping="Wrap"
              MinHeight="150"
              MaxHeight="300"
              Watermark="Enter custom words (one per line)..."
              Text="{Binding CustomProfanityWordsText}"
            />
            <Button
              Content="Apply"
              Command="{Binding ApplyCustomWordsCmd}"
              HorizontalAlignment="Right"
            />
          </StackPanel>
        </ui:SettingsExpanderItem>
      </ui:SettingsExpander>
      <!-- Friends -->
      <ui:SettingsExpander
        Header="Friends"
        IconSource="{icm:SymbolIconSource Symbol=People}"
      >
        <ui:SettingsExpanderItem Content="Notify when a tracked friend comes online">
          <ui:SettingsExpanderItem.Footer>
            <ToggleSwitch IsChecked="{Binding Config.Friends.NotifyOnline}" />
          </ui:SettingsExpanderItem.Footer>
        </ui:SettingsExpanderItem>
      </ui:SettingsExpander>
      <ui:SettingsExpander
        Header="AI Summarization"
        IconSource="{icm:SymbolIconSource Symbol=Bot}"
      >
        <ui:SettingsExpanderItem Content="Enable AI summarization">
          <ui:SettingsExpanderItem.Footer>
            <ToggleSwitch IsChecked="{Binding Config.Ai.Enabled}" />
          </ui:SettingsExpanderItem.Footer>
        </ui:SettingsExpanderItem>
        <ui:SettingsExpanderItem>
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="120,*">
              <TextBlock Grid.Column="0" Text="Provider:" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1" SelectedIndex="{Binding ProviderIndex}">
                <ComboBoxItem Content="Ollama (local)" />
                <ComboBoxItem Content="Gemini (cloud)" />
              </ComboBox>
            </Grid>
            <Grid ColumnDefinitions="120,*">
              <TextBlock Grid.Column="0" Text="Max messages:" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Value="{Binding Config.Ai.MaxMessages}" Minimum="50" Maximum="1000" Increment="50" />
            </Grid>

            <StackPanel Spacing="8" IsVisible="{Binding IsOllamaSelected}">
              <Separator Margin="0,8" />
              <TextBlock Text="Ollama (local)" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding Config.Ai.OllamaEndpoint}" Watermark="http://localhost:11434" />
              </Grid>
              <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding Config.Ai.Model}" Watermark="llama3.1:8b" />
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Test connection" Command="{Binding TestOllamaConnectionCmd}" />
                <TextBlock Text="{Binding OllamaConnectionStatus}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              </StackPanel>
            </StackPanel>

            <StackPanel Spacing="8" IsVisible="{Binding IsGeminiSelected}">
              <Separator Margin="0,8" />
              <TextBlock Text="Gemini (cloud)" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="API key:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding Config.Ai.GeminiApiKey}" PasswordChar="•"
                         Watermark="Coller la clé API Google AI Studio" />
              </Grid>
              <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding Config.Ai.GeminiModel}" Watermark="gemini-flash-latest" />
              </Grid>
              <TextBlock Text="Clé gratuite sur https://aistudio.google.com/app/apikey"
                         FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Test connection" Command="{Binding TestGeminiConnectionCmd}" />
                <TextBlock Text="{Binding GeminiConnectionStatus}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              </StackPanel>
            </StackPanel>
            <StackPanel Spacing="6">
              <DockPanel LastChildFill="False">
                <TextBlock Text="System prompt:" VerticalAlignment="Center" DockPanel.Dock="Left" />
                <Button Content="Reset prompt" Command="{Binding ResetPromptCmd}" DockPanel.Dock="Right" />
              </DockPanel>
              <TextBox Text="{Binding Config.Ai.SystemPrompt}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="200"
                       MaxHeight="400"
                       VerticalContentAlignment="Top"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="11"
                       ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </StackPanel>
          </StackPanel>
        </ui:SettingsExpanderItem>
      </ui:SettingsExpander>
      <ui:SettingsExpander
        Header="Debug"
        IsVisible="{DynamicResource IsDebug}"
        IconSource="{icm:SymbolIconSource Symbol=Bug}"
      >
        <CheckBox IsChecked="{Binding Config.General.PrivacyMode}" Content="Privacy mode" />
      </ui:SettingsExpander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
