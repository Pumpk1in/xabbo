<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="using:FluentAvalonia.UI.Controls"
  xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
  xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
  xmlns:vm="using:Xabbo.ViewModels"
  mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
  x:Class="Xabbo.Avalonia.Views.ChatSummaryDialogView"
  x:DataType="vm:ChatSummaryDialogViewModel"
  MinWidth="500" MinHeight="400">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">

    <StackPanel Grid.Row="0" Spacing="2">
      <TextBlock Text="{Binding MessageCount, StringFormat='{}{0} messages'}"
                 FontSize="12"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
      <TextBlock Text="{Binding ModelName}"
                 FontSize="12"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                 IsVisible="{Binding ModelName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>

    <Border Grid.Row="1"
            Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
            BorderBrush="{DynamicResource SystemFillColorCautionBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,6"
            IsVisible="{Binding WarningMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap" FontSize="12" />
    </Border>

    <ProgressBar Grid.Row="2"
                 IsIndeterminate="True"
                 Height="2"
                 IsVisible="{Binding IsStreaming}" />

    <md:MarkdownScrollViewer Grid.Row="3"
                              x:Name="SummaryScrollViewer"
                              Markdown="{Binding SummaryText}">
      <md:MarkdownScrollViewer.Styles>
        <Style Selector="ctxt|CTextBlock">
          <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading1">
          <Setter Property="FontSize" Value="18" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading2">
          <Setter Property="FontSize" Value="16" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading3">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading4">
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading5">
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ctxt|CTextBlock.Heading6">
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
      </md:MarkdownScrollViewer.Styles>
    </md:MarkdownScrollViewer>

    <StackPanel Grid.Row="4" Spacing="8">
      <Border Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
              BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8,6"
              IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" FontSize="12" />
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Content="Cancel" Command="{Binding CancelCmd}" />
        <Button Content="Copy" Command="{Binding CopyCmd}" />
        <Button Content="Regenerate" Command="{Binding RegenerateCmd}" />
      </StackPanel>
    </StackPanel>
  </Grid>
</UserControl>
